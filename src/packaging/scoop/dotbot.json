{
    "version": "3.5.0",
    "description": "Structured AI-assisted development framework with two-phase execution and web dashboard",
    "homepage": "https://github.com/andresharpe/dotbot",
    "license": "MIT",
    "url": "https://github.com/andresharpe/dotbot/releases/download/v3.5.0/dotbot-3.5.0.zip",
    "hash": "skip",
    "extract_dir": "dotbot-3.5.0",
    "suggest": {
        "PowerShell 7+": "pwsh"
    },
    "bin": [
        ["bin\\shim\\dotbot.cmd", "dotbot"],
        ["bin\\shim\\dotbot.ps1", "dotbot.ps1"]
    ],
    "notes": [
        "dotbot ships only a PATH shim. The framework lives under the install dir; ",
        "point DOTBOT_HOME at a dotbot checkout you control:",
        "  $env:DOTBOT_HOME = \"$($dir)\"          # use the scoop-installed copy",
        "  $env:DOTBOT_HOME = \"$HOME/code/dotbot\"  # or your own clone",
        "Persist with: setx DOTBOT_HOME <path>",
        "Then 'dotbot status' confirms the active tree."
    ],
    "checkver": {
        "github": "https://github.com/andresharpe/dotbot"
    },
    "autoupdate": {
        "url": "https://github.com/andresharpe/dotbot/releases/download/v$version/dotbot-$version.zip",
        "extract_dir": "dotbot-$version",
        "hash": "skip"
    }
}
