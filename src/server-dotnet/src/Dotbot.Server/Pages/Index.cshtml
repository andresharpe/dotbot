@page
@model Dotbot.Server.Pages.IndexModel
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Fleet";
    ViewData["UserName"] = Model.UserName;
    ViewData["ActiveRail"] = "fleet";
}

@* Fleet dashboard (#547) — the Mothership landing surface. Static skeleton hydrated
   by /js/fleet.js from /api/fleet/* (mock data now; live wiring in #598). *@

<!-- Active alert banner (highest-severity open alerts) -->
<div class="fleet-alert-banner" id="fleet-alert-banner" style="display:none;" role="alert"></div>

<!-- Fleet overview stats -->
<div class="stats-row">
    <div class="stat-card">
        <div class="stat-value" id="stat-total">0</div>
        <div class="stat-label">Instances</div>
    </div>
    <div class="stat-card">
        <div class="stat-value stat-online" id="stat-online">0</div>
        <div class="stat-label">Online</div>
    </div>
    <div class="stat-card">
        <div class="stat-value stat-stale" id="stat-stale">0</div>
        <div class="stat-label">Stale</div>
    </div>
    <div class="stat-card">
        <div class="stat-value stat-error" id="stat-error">0</div>
        <div class="stat-label">Error</div>
    </div>
    <div class="stat-card">
        <div class="stat-value" id="stat-drones">0</div>
        <div class="stat-label">Drones</div>
    </div>
    <div class="stat-card">
        <div class="stat-value stat-alerts" id="stat-alerts">0</div>
        <div class="stat-label">Active Alerts</div>
    </div>
</div>

<!-- Instance health cards -->
<div class="module">
    <div class="module-header">
        <span>INSTANCES <span class="instance-count-badge" id="fleet-instance-count">0</span></span>
    </div>
    <div class="module-screen">
        <div class="fleet-instance-grid" id="fleet-instances-list"></div>
        <div class="empty-state" id="fleet-instances-empty" style="display:none;">
            No instances registered.
        </div>
    </div>
</div>

<!-- Notification rail: active alerts -->
<div class="module">
    <div class="module-header">
        <span>ALERTS <span class="instance-count-badge" id="fleet-alerts-count">0</span></span>
    </div>
    <div class="module-screen">
        <div class="fleet-alert-list" id="fleet-alerts-active"></div>
        <div class="empty-state" id="fleet-alerts-empty" style="display:none;">
            No active alerts.
        </div>
    </div>
</div>

<!-- Alert history: cleared alerts with resolved timestamps -->
<div class="module">
    <div class="module-header">
        <span>ALERT HISTORY <span class="instance-count-badge" id="fleet-history-count">0</span></span>
    </div>
    <div class="module-screen">
        <div class="fleet-alert-list" id="fleet-alerts-history"></div>
        <div class="empty-state" id="fleet-history-empty" style="display:none;">
            No cleared alerts.
        </div>
    </div>
</div>

@section Scripts {
    <script src="/js/fleet.js"></script>
}
