{
  "name": "antigravity",
  "display_name": "Antigravity (Google)",
  "executable": "agy",
  "exec_subcommand": null,
  "prompt_flag": null,
  "models": {
    "gemini-3-pro":   { "id": "gemini-3-pro",   "description": "Most capable Antigravity model", "badge": "Recommended" },
    "gemini-3-flash": { "id": "gemini-3-flash", "description": "Fast and efficient" }
  },
  "default_model": "gemini-3-pro",
  "permission_modes": {
    "yolo": {
      "display_name": "YOLO",
      "description": "Auto-approve all tool calls without prompts.",
      "cli_args": "-y"
    },
    "auto_edit": {
      "display_name": "Auto Edit",
      "description": "Auto-approve file edits, prompt for shell commands.",
      "cli_args": ["--approval-mode", "auto_edit"]
    }
  },
  "default_permission_mode": "yolo",
  "cli_args": {
    "model": "-m",
    "stream_format": ["--output-format", "stream-json"],
    "print": null,
    "verbose": null,
    "session_id": null,
    "no_session_persistence": null
  },
  "capabilities": {
    "session_id": false,
    "persist_session": false
  },
  "adapter": "Antigravity",
  "ide_dir": ".agents"
}
