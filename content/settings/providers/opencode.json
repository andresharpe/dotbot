{
  "name": "opencode",
  "display_name": "OpenCode (SST)",
  "executable": "opencode",
  "exec_subcommand": "run",
  "prompt_flag": null,
  "models": {
    "sonnet":   { "id": "anthropic/claude-sonnet-4-6",  "description": "Anthropic Sonnet via OpenCode", "badge": "Recommended" },
    "opus":     { "id": "anthropic/claude-opus-4-7",    "description": "Anthropic Opus via OpenCode" },
    "gpt-5":    { "id": "openai/gpt-5.4",               "description": "OpenAI GPT-5 via OpenCode" },
    "gemini-3": { "id": "google/gemini-3-pro-preview",  "description": "Google Gemini via OpenCode" }
  },
  "default_model": "sonnet",
  "permission_modes": {
    "bypass": {
      "display_name": "Bypass Permissions",
      "description": "Auto-approve permissions that are not explicitly denied (dangerous!).",
      "cli_args": "--dangerously-skip-permissions"
    }
  },
  "default_permission_mode": "bypass",
  "cli_args": {
    "model": "--model",
    "stream_format": ["--format", "json"],
    "print": null,
    "verbose": null,
    "session_id": "--session",
    "working_directory": "--dir",
    "no_session_persistence": null
  },
  "capabilities": {
    "session_id": true,
    "persist_session": true
  },
  "adapter": "OpenCode",
  "ide_dir": ".opencode",
  "mcp_setup": null,
  "env_key": "ANTHROPIC_API_KEY"
}
