      "output_per_mtok": 25.0,
      "is_latest": false,
      "description": "Pinned to Opus 4.6 (legacy)"
    }
  },
  "default_model": "Opus",
  "permission_modes": {
    "bypassPermissions": {
      "display_name": "Bypass Permissions",
      "description": "Skips all permission checks. Works on all plans and models.",
      "cli_args": "--dangerously-skip-permissions"
    },
    "auto": {
      "display_name": "Auto Mode",
      "description": "AI classifier approves or blocks actions. Requires Team, Enterprise, or API plan. Haiku not supported.",
      "cli_args": ["--permission-mode", "auto"],
      "restrictions": {
        "excluded_models": ["Haiku"]
      }
    }
  },
  "default_permission_mode": "bypassPermissions",
  "cli_args": {
    "model": "--model",
    "permissions_bypass": "--dangerously-skip-permissions",
    "stream_format": ["--output-format", "stream-json"],
    "print": "--print",
    "verbose": "--verbose",
    "session_id": "--session-id",
    "no_session_persistence": "--no-session-persistence"
  },
  "capabilities": {
    "session_id": true,
    "persist_session": true
  },
  "stream_parser": "Claude",
  "ide_dir": ".claude",
  "mcp_setup": "mcp-json",
  "env_key": "ANTHROPIC_API_KEY"
}
